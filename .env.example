# ══════════════════════════════════════════════════════════════
#  SmartTask — Environment Variables
#  Copy this file:  cp .env.example .env
#  Then customize values as needed.
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ──
POSTGRES_DB=smarttask_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── MongoDB ──
MONGODB_DATABASE=smarttask_dev

# ── Application ──
SPRING_PROFILES_ACTIVE=docker
JWT_SECRET=docker-dev-secret-key-this-should-be-at-least-64-characters-long-for-hmac-sha512-algorithm
